  "keyFeatures": [
    "Admin-approved investor onboarding with email notification",
    "Live SPCX stock quote and price history chart via FMP API",
    "Crypto deposits (BTC, ETH, DOGE) with admin-managed wallet addresses",
    "Manual share crediting by admin with weighted average cost basis",
    "Anonymous admin panel accessible only via passcode",
    "Investor holdings tracking with real-time portfolio value",
    "Investor Updates news feed with bond issuance and equity offering announcements",
    "In-app AI support chat with account and order assistance",
    "Passkey authentication support",
    "Mobile-first dark space-themed UI"
  ],
